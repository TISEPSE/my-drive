# PostgreSQL
POSTGRES_USER=cloudspace
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_DB=cloudspace_db

# Flask
SECRET_KEY=change-me-use-a-long-random-string

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# GitHub OAuth (https://github.com/settings/developers → OAuth Apps)
# Callback URL to register: http://localhost:8080/api/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
